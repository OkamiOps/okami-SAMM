# ---- servidor ----
PORT=3000
DB_PATH=./data/okami-samm.db

# CORS — só necessário se o frontend chamar a API direto (sem o proxy do Pages).
# Ex.: https://okami-samm.pages.dev   (ou "*" para liberar geral)
CORS_ORIGIN=

# ---- IA (opcional) ----
# Provider: openai | anthropic. Sem chave, o botão de IA fica escondido.
# Cobre OpenAI, Minimax e qualquer endpoint OpenAI-compatível (via AI_BASE_URL),
# além da API Anthropic com URL custom.
AI_PROVIDER=
AI_BASE_URL=
AI_API_KEY=
AI_MODEL=

# Exemplos:
#   OpenAI:    AI_PROVIDER=openai    AI_MODEL=gpt-4o-mini
#   Minimax:   AI_PROVIDER=openai    AI_BASE_URL=https://api.minimax.io/v1   AI_MODEL=...
#   Anthropic: AI_PROVIDER=anthropic AI_MODEL=claude-sonnet-4-6
#   Anthropic custom URL: AI_PROVIDER=anthropic AI_BASE_URL=https://seu-proxy/anthropic
