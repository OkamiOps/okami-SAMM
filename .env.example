# ---- server / servidor ----
PORT=3000
DB_PATH=./data/okami-samm.db

# ---- auth ----
# Secret to sign session cookies; auto-generated and stored in the DB if empty.
# Set explicitly if you run multiple instances.
# Segredo para assinar os cookies de sessão; gerado e salvo no banco se vazio.
AUTH_SECRET=
# Set COOKIE_SECURE=1 when serving over HTTPS. / Defina ao servir via HTTPS.
COOKIE_SECURE=

# CORS — only needed if the frontend calls the API directly (without the Pages proxy).
# CORS — só necessário se o frontend chamar a API direto (sem o proxy do Pages).
# e.g. / ex.: https://okami-samm.pages.dev   (or "*" to allow all / ou "*" para liberar geral)
CORS_ORIGIN=

# ---- AI (optional / opcional) ----
# Provider: openai | anthropic. Without a key the AI button stays hidden.
# Provider: openai | anthropic. Sem chave, o botão de IA fica escondido.
# Covers OpenAI, Minimax and any OpenAI-compatible endpoint (via AI_BASE_URL),
# plus the Anthropic API with a custom URL.
# Cobre OpenAI, Minimax e qualquer endpoint OpenAI-compatível (via AI_BASE_URL),
# além da API Anthropic com URL custom.
AI_PROVIDER=
AI_BASE_URL=
AI_API_KEY=
AI_MODEL=

# Examples / Exemplos:
#   OpenAI:    AI_PROVIDER=openai    AI_MODEL=gpt-4o-mini
#   Minimax:   AI_PROVIDER=openai    AI_BASE_URL=https://api.minimax.io/v1   AI_MODEL=...
#   Anthropic: AI_PROVIDER=anthropic AI_MODEL=claude-sonnet-4-6
#   Anthropic custom URL / URL custom: AI_PROVIDER=anthropic AI_BASE_URL=https://your-proxy/anthropic
