{
  "name": "okami-samm",
  "version": "1.0.0",
  "private": true,
  "description": "Okami SAMM — OWASP SAMM maturity assessment app with SQLite persistence and Okami-branded PDF reports",
  "type": "commonjs",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "node --watch server/index.js",
    "mcp": "node server/mcp-stdio.js",
    "acp": "node server/acp-client-stdio.js",
    "test": "node tests/run.js",
    "postinstall": "node -e \"try{require('playwright').chromium}catch(e){}\"",
    "browser": "playwright install chromium"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^11.8.1",
    "express": "^4.21.2",
    "playwright": "^1.49.1",
    "zod": "^4.4.3"
  }
}
